POSTGRES_DB=inventory-service
POSTGRES_USER=inventory-service-user
POSTGRES_PASSWORD=inventory-service-password
POSTGRES_PORT=7433

DB_URI=postgres://inventory-service-user:inventory-service-password@localhost:7433/inventory-service?sslmode=disable
MIGRATIONS_DIR=migrations/inventory

# Версии Docker-образов
POSTGRES_IMAGE=postgres:18.3-alpine3.23
